option_settings:
  aws:elasticbeanstalk:container:python:
    NumProcesses: 1
    NumThreads: 15

container_commands:
  01_install_build_tools:
    command: "yum install -y python3-devel gcc-c++ make"
    ignoreErrors: true
  02_upgrade_pip:
    command: "pip install --upgrade pip"
    ignoreErrors: true
  03_install_numpy_first:
    command: "pip install numpy==1.26.2"
    ignoreErrors: true
  04_install_scipy:
    command: "pip install scipy==1.11.4"
    ignoreErrors: true
  05_install_sklearn:
    command: "pip install scikit-learn==1.3.2"
    ignoreErrors: true
  06_install_xgboost:
    command: "pip install xgboost==2.0.3"
    ignoreErrors: true
  07_install_rest:
    command: "pip install flask==3.0.0 gunicorn==21.2.0 pandas==2.1.4 requests==2.31.0 tldextract==5.1.1 python-Levenshtein==0.23.0 joblib==1.3.2"
    ignoreErrors: true
