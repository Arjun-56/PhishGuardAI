commands:
  01_create_log_dir:
    command: "mkdir -p /var/log/app"
    ignoreErrors: true

container_commands:
  01_install_dev_tools:
    command: "dnf install -y gcc gcc-c++ python3-devel make cmake"
    ignoreErrors: true
  02_install_numpy_scipy:
    command: "pip install --no-cache-dir numpy==1.24.3 scipy==1.10.1"
    ignoreErrors: true
  03_install_sklearn:
    command: "pip install --no-cache-dir scikit-learn==1.3.0"
    ignoreErrors: true
  04_install_xgboost:
    command: "pip install --no-cache-dir xgboost==1.7.6"
    ignoreErrors: true
  05_install_flask_deps:
    command: "pip install --no-cache-dir flask==2.3.3 gunicorn==21.2.0 pandas==2.0.3 requests==2.31.0 tldextract==3.4.4 python-Levenshtein==0.21.1 joblib==1.3.2 shap==0.42.1"
    ignoreErrors: true
  06_verify_installation:
    command: "python -c 'import flask; import sklearn; import xgboost; print(\"All packages installed successfully\")' >> /var/log/eb-engine.log 2>&1"
    ignoreErrors: true
